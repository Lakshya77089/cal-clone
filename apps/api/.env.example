# Neon (or any Postgres) — pooled connection string used by the app at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&pgbouncer=true&connection_limit=1"

# Neon — direct (non-pooled) connection, used only by `prisma migrate`.
# For local Docker Postgres, set this to the same value as DATABASE_URL.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# CORS: the origin allowed to call the API. Comma-separated for multiple.
WEB_ORIGIN="http://localhost:3000"

# Port the API listens on.
PORT=4000

# EmailJS — booking notifications. Leave all blank to disable email sending
# (booking still works, no emails are sent).
# Sign up at emailjs.com, create a service + a template, then paste:
EMAILJS_SERVICE_ID=""
EMAILJS_TEMPLATE_ID=""
EMAILJS_PUBLIC_KEY=""
# Required only if your EmailJS account has "Allow EmailJS API for non-browser
# applications" turned OFF (the default for new accounts).
EMAILJS_PRIVATE_KEY=""
