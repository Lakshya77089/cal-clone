# Public base URL for the Express API.
# Local dev: http://localhost:4000
# Production: your Render URL, e.g. https://cal-api.onrender.com
NEXT_PUBLIC_API_URL="http://localhost:4000"

# (Optional) Internal API URL used by server components.
# If unset, falls back to NEXT_PUBLIC_API_URL.
INTERNAL_API_URL=""
